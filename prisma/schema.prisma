generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  name        String
  category    String
  description String
  specs       String
  price       Float
  image       String
}
